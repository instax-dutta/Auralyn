# Discord Bot Token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Client ID (required for command registration)
CLIENT_ID=your_discord_client_id_here

# Discord Guild ID (optional, for testing commands instantly)
GUILD_ID=your_discord_guild_id_here

# Log level (optional: debug, info, warn, error)
LOG_LEVEL=info

# Persistent data directory (optional). Default: /app/data
# Stores guild-settings.json, sessions.json, commands.hash.
# Set to ./data for local development.
DATA_DIR=/app/data

# Global slash-command sync on startup (optional, default true).
# When true, the bot hashes the command payloads and only re-deploys
# if they have changed since the last successful sync — protects the
# 200 global command updates/day rate limit during container restarts.
AUTO_SYNC_GLOBAL_COMMANDS=true

# Lavalink Password (required)
LAVALINK_PASSWORD=change_me

# Lavalink Memory (optional, default is 1G)
LAVALINK_MEMORY=1G

# Lavalink Startup Timeout (optional, default is 60 seconds)
LAVALINK_STARTUP_TIMEOUT=60

# Spotify Client ID (optional, enables LavaSrc Spotify source)
# Obtain from https://developer.spotify.com/dashboard → Create App
SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Spotify Client Secret (optional, paired with SPOTIFY_CLIENT_ID)
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ── Guild Feature Defaults ──────────────────────────────────
# These are the default values applied to every guild.
# Customize per-guild at runtime via the settings store at /app/data/guild-settings.json
#
# Feature          Default   Description
# autoplay         false     Automatically queue related tracks when the queue ends
# twentyFourSeven  false     Stay connected to voice even when alone
# voteSkipEnabled  false     Enable vote-skip (skip succeeds when threshold% of listeners vote)
# voteSkipThreshold 50       Percentage of voice listeners required for vote-skip to pass
