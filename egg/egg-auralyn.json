{
  "name": "Auralyn",
  "author": "YourName",
  "description": "A Discord music bot with Lavalink v4 built-in",
  "features": {
    "docker": {
      "image": "ghcr.io/yourrepo/auralyn:latest",
      "app": {
        "startup": {
          "done": "Starting Auralyn bot",
          "container": {
            "startup": {
              "general": [
                {
                  "action": "wait",
                  "timeout": 5,
                  "output": "Starting Auralyn bot"
                },
                {
                  "action": "stop"
                }
              ]
            }
          }
        },
        "stop": "kill $(cat /app/lavalink.pid) && kill $(cat /app/bot.pid)"
      },
      "configs": {
        "files": {
          "app/.env": "env"
        },
        "location": "app"
      }
    },
    "process": {
      "name": "Auralyn",
      "mappings": {
        "startup": {
          "done": {
            "match": "Auralyn bot started successfully"
          }
        }
      },
      "default": {
        "run": "/app/scripts/start.sh"
      }
    },
    "logs": {
      "custom": {
        "location": "logs"
      }
    },
    "mounts": {
      "configs": [
        {
          "source": "lavalink/logs",
          "target": "/app/lavalink/logs"
        },
        {
          "source": "logs",
          "target": "/app/logs"
        }
      ]
    }
  },
  "variables": [
    {
      "name": "DISCORD_TOKEN",
      "description": "Your Discord bot token",
      "envVariable": "DISCORD_TOKEN",
      "defaultValue": "",
      "userViewable": false
    },
    {
      "name": "CLIENT_ID",
      "description": "Your Discord client ID",
      "envVariable": "CLIENT_ID",
      "defaultValue": ""
    },
    {
      "name": "GUILD_ID",
      "description": "Your Discord server ID (for guild commands)",
      "envVariable": "GUILD_ID",
      "defaultValue": ""
    },
    {
      "name": "LAVALINK_PASSWORD",
      "description": "Lavalink server password",
      "envVariable": "LAVALINK_PASSWORD",
      "defaultValue": "youshallnotpass"
    },
    {
      "name": "LAVALINK_MEMORY",
      "description": "Memory allocated to Lavalink (e.g., 1G, 2G)",
      "envVariable": "LAVALINK_MEMORY",
      "defaultValue": "1G"
    },
    {
      "name": "LAVALINK_STARTUP_TIMEOUT",
      "description": "Timeout in seconds for Lavalink to start",
      "envVariable": "LAVALINK_STARTUP_TIMEOUT",
      "defaultValue": "60"
    },
    {
      "name": "SPOTIFY_CLIENT_ID",
      "description": "Spotify client ID for LavaSrc plugin",
      "envVariable": "SPOTIFY_CLIENT_ID",
      "defaultValue": ""
    },
    {
      "name": "SPOTIFY_CLIENT_SECRET",
      "description": "Spotify client secret for LavaSrc plugin",
      "envVariable": "SPOTIFY_CLIENT_SECRET",
      "defaultValue": ""
    }
  ],
  "thumbnail": "https://example.com/auralyn.png"
}